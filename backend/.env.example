# Flavr Backend - Environment Variables
# WICHTIG: .env.local NICHT in Git committen!
# Railway/Production verwendet GitHub Secrets

# Supabase
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Claude API
CLAUDE_API_KEY=sk-ant-...

# Unsplash (für Rezeptbild-Vorschläge mit prefer=unsplash)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Bring (falls verwendet)
BRING_API_KEY=your_bring_api_key_here

# Server
PORT=3000
NODE_ENV=development

