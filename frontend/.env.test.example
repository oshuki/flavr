# E2E Test Environment Variables
# Kopiere diese Datei zu .env.test und fülle die Werte aus

# Supabase Auth Token für authentifizierte Tests
# Wie bekomme ich den Token?
# 1. Lokal einloggen: npm run dev → http://localhost:3002
# 2. DevTools Console: localStorage.getItem('sb-htescszituyzooubmxkh-auth-token')
# 3. Kompletten JSON-String kopieren
SUPABASE_TEST_TOKEN='{"access_token":"eyJ...", "refresh_token":"...", ...}'

# Test User Credentials (für Dokumentation, werden für Google OAuth nicht verwendet)
TEST_USER_EMAIL=oshuki@gmail.com
TEST_USER_PASSWORD=prudens

# Test Base URL (optional, default: http://localhost:3002)
PLAYWRIGHT_TEST_BASE_URL=https://flavr-nuxt.pages.dev

# Auth-Tests überspringen?
SKIP_AUTH_TESTS=false
